<%- include('partials/header') %>

<section class="hero card hero-card">
  <div class="hero-copy">
    <p class="eyebrow">快速查榜</p>
    <h2>先看段位，再看细项。</h2>
    <p class="hero-text">直接搜名字就能定位玩家，榜单按排名排好，细分项目一眼就能看清。</p>
  </div>

  <div class="hero-actions">
    <label class="search-wrap" for="searchInput">
      <span>搜索玩家</span>
      <input id="searchInput" type="search" placeholder="输入名字快速过滤" autocomplete="off" />
    </label>

    <div class="hero-stats">
      <div class="stat-card">
        <strong><%= stats.totalPlayers %></strong>
        <span>名玩家</span>
      </div>
      <div class="stat-card">
        <strong><%= stats.totalCategories %></strong>
        <span>个细项</span>
      </div>
    </div>
  </div>
</section>

<section class="card">
  <table id="leaderboardTable">
    <thead>
      <tr>
        <th>排名</th>
        <th>玩家</th>
        <th>段位</th>
        <th>积分</th>
        <th>细分项目</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach((entry) => { %>
      <tr data-player="<%= entry.player.toLowerCase() %>" class="leaderboard-row">
        <td>#<%= entry.position %></td>
        <td><strong><%= entry.player %></strong></td>
        <td><span class="badge"><%= entry.rank %></span></td>
        <td><%= entry.points %></td>
        <td>
          <div class="chips">
            <% Object.entries(entry.categories || {}).forEach(([key, val]) => { if (val) { %>
            <span class="chip"><%= key %>: <%= val %></span>
            <% } }) %>
          </div>
        </td>
      </tr>
      <% }) %>
      <tr id="emptyStateRow" class="empty-state-row" hidden>
        <td colspan="5">没有找到符合条件的玩家，换个名字试试。</td>
      </tr>
    </tbody>
  </table>
</section>

<script src="/public/main.js"></script>
<%- include('partials/footer') %>
