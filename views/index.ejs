<%- include('partials/header') %>

<section class="hero card hero-card">
  <div class="hero-copy">
    <p class="eyebrow">快速查榜</p>
    <h2>榜单总览</h2>
    <p class="hero-text">此榜为娱乐性质，数据来源于Pico's Subtier</p>
  </div>

  <div class="hero-actions">
    <label class="search-wrap" for="searchInput">
      <span>搜索玩家</span>
      <input id="searchInput" type="search" placeholder="输入名字快速过滤" autocomplete="off" />
    </label>

    <div class="hero-stats">
      <div class="stat-card">
        <strong><%= stats.totalPlayers %></strong>
        <span>名玩家</span>
      </div>
      <div class="stat-card">
        <strong><%= stats.totalCategories %></strong>
        <span>个细项</span>
      </div>
    </div>
  </div>
</section>

<section class="card">
  <table id="leaderboardTable">
    <thead>
      <tr>
        <th data-sort="position">排名</th>
        <th data-sort="player">玩家</th>
        <th data-sort="rank">段位</th>
        <th data-sort="points">积分</th>
        <th data-sort="categories">细分项目</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach((entry) => { %>
      <tr data-player="<%= entry.player.toLowerCase() %>" data-position="<%= entry.position %>" data-rank="<%= entry.rank %>" data-points="<%= entry.points %>" class="leaderboard-row">
        <td data-label="排名">#<%= entry.position %></td>
        <td data-label="玩家">
          <strong class="player-name <%= Number(entry.position) === 1 ? 'rank-1' : Number(entry.position) === 2 ? 'rank-2' : Number(entry.position) === 3 ? 'rank-3' : '' %>">
            <% if (Number(entry.position) === 1) { %><span class="rank-icon">👑</span><% } %>
            <% if (Number(entry.position) === 2) { %><span class="rank-icon">🥈</span><% } %>
            <% if (Number(entry.position) === 3) { %><span class="rank-icon">🥉</span><% } %>
            <%= entry.player %>
          </strong>
        </td>
        <td data-label="段位"><span class="badge" data-rank="<%= entry.rank %>"><%= entry.rank %></span></td>
        <td data-label="积分"><%= entry.points %></td>
        <td data-label="细分项目">
          <div class="chips">
            <% Object.entries(entry.categories || {}).forEach(([key, val]) => { if (val) { %>
            <span class="chip"><%= key %>: <%= val %></span>
            <% } }) %>
          </div>
        </td>
      </tr>
      <% }) %>
      <tr id="emptyStateRow" class="empty-state-row" hidden>
        <td colspan="5">
          <div class="admin-empty-state">
            <h3>没有找到该玩家</h3>
            <p>请尝试搜索其他关键词</p>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</section>

<script src="/public/main.js"></script>
<%- include('partials/footer') %>
