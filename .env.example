# 基础
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# 会话
SESSION_SECRET=replace-with-long-random-string

# 初始 SuperAdmin（仅首次启动写入 data/users.json）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe_12345

# 邮件（注册验证）
# 在 https://resend.com/api-keys 创建 API key
RESEND_API_KEY=
EMAIL_FROM=Subtier Staff <schale@bluearchive.site>

# Microsoft OAuth（client_id 也可在后台 /admin/settings 中编辑）
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_TENANT=common
